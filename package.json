{
  "name": "pathkeep",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "desktop:dev": "tauri dev",
    "desktop:dev:bridge": "node scripts/pathkeep-dev-desktop-bridge.mjs",
    "build": "tsc -b && vite build",
    "desktop:build": "tauri build",
    "desktop:build:debug": "tauri build --debug --no-bundle",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -b --pretty false",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:desktop-contract": "vitest run --config vitest.desktop-contract.config.ts",
    "coverage:js": "vitest run --config vitest.quality.config.ts --coverage",
    "coverage:js:desktop-contract": "vitest run --config vitest.desktop-contract.config.ts --coverage",
    "check:desktop-contract": "bun run test:unit:desktop-contract && bun run coverage:js:desktop-contract && bun run mutation:js:desktop-contract",
    "test:e2e": "playwright test",
    "test:e2e:desktop-bridge": "playwright test --config playwright.desktop-bridge.config.ts",
    "test:e2e:desktop-bridge:headed": "playwright test --config playwright.desktop-bridge.config.ts --headed",
    "test:platform:rust": "node scripts/run-platform-rust-tests.mjs",
    "test:platform:desktop": "node scripts/run-platform-desktop-tests.mjs",
    "test:desktop-bridge:rust": "cargo test --manifest-path src-tauri/Cargo.toml -p pathkeep-desktop --features devtools-bridge dev_ipc_bridge",
    "test:unit:product-flows": "vitest run src/app/index.test.tsx src/pages/trust-flows.test.tsx src/pages/intelligence-surfaces.test.tsx",
    "fmt:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all --check",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --workspace --all-targets --all-features -- -D warnings",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --workspace --all-targets",
    "coverage:rust:raw": "cargo llvm-cov --manifest-path src-tauri/Cargo.toml --workspace --all-features --lcov --output-path coverage/rust.lcov.info",
    "coverage:rust": "bun run coverage:rust:raw && node scripts/verify-rust-coverage.mjs coverage/rust.lcov.info quality",
    "mutation:rust:parser": "cargo mutants --manifest-path src-tauri/Cargo.toml -p browser-history-parser --timeout 300",
    "mutation:rust:ai-helpers": "cargo mutants --manifest-path src-tauri/Cargo.toml -p vault-core --file crates/vault-core/src/ai.rs -F 'ai_index_status|ai_queue_status|reconcile_ai_queue_controls|provider_capabilities|provider_connection_failure_report|test_provider_connection' --timeout 300",
    "mutation:rust": "bun run mutation:rust:parser && bun run mutation:rust:ai-helpers",
    "mutation:rust:full": "cargo mutants --manifest-path src-tauri/Cargo.toml --workspace --test-tool cargo --timeout 300",
    "mutation:js": "stryker run",
    "mutation:js:desktop-contract": "stryker run stryker.desktop-contract.config.json",
    "mutation": "bun run mutation:js && bun run mutation:rust",
    "audit:rust": "bun scripts/check-rust-security.mjs",
    "deny:rust": "cd src-tauri && cargo deny check bans licenses sources",
    "check:supply-chain": "bun run audit:rust && bun run deny:rust",
    "check:platform": "node scripts/run-platform-checks.mjs",
    "check:coverage": "bun run coverage:js && bun run coverage:rust",
    "check:js": "bun run format:check && bun run lint && bun run typecheck && bun run test:unit",
    "check:rust": "bun run fmt:rust && bun run lint:rust && bun run test:rust",
    "check": "bun run check:js && bun run check:desktop-contract && bun run check:rust && bun run check:supply-chain && bun run check:platform",
    "check:full": "bun run check && bun run coverage && bun run mutation && bun run test:e2e",
    "coverage": "bun run check:coverage",
    "ci:local": "bun run check && bun run coverage && bun run build && bun run test:e2e && bun run desktop:build:debug",
    "docs:llm": "bun scripts/build-llm-txt.mjs",
    "perf:artifact:shell": "bun scripts/build-perf-artifact-bundle.mjs",
    "release:bump": "node scripts/bump-version.mjs",
    "release:size-audit": "node scripts/build-release-size-audit.mjs",
    "preview": "vite preview",
    "verify": "bun run check:full && bun run build && bun run desktop:build:debug"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.4.3",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-stronghold": "^2.3.1",
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
