{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Browser History Backup",
  "version": "0.1.0",
  "identifier": "dev.codex.browser-history-backup",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Browser History Backup",
        "width": 1480,
        "height": 960,
        "minWidth": 1080,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns"]
  }
}
