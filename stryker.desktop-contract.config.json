{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "checkers": ["typescript"],
  "reporters": ["clear-text", "progress"],
  "ignorePatterns": [
    "src-tauri/target/**",
    "coverage/**",
    "dist/**",
    "output/**",
    "test-results/**",
    "var/**"
  ],
  "mutate": [
    "src/main.tsx",
    "src/lib/ipc/bridge.ts",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx"
  ],
  "coverageAnalysis": "all",
  "disableTypeChecks": "src/**/*.{ts,tsx}",
  "allowConsoleColors": true,
  "tempDirName": "reports/mutation/.stryker-desktop-contract-tmp",
  "thresholds": {
    "high": 100,
    "low": 100,
    "break": 100
  },
  "vitest": {
    "configFile": "vitest.desktop-contract.config.ts"
  }
}
