{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "checkers": ["typescript"],
  "reporters": ["clear-text", "progress"],
  "mutate": [
    "src/main.tsx",
    "src/app/**/*.tsx",
    "src/components/sidebar/**/*.tsx",
    "src/components/topbar/**/*.tsx",
    "src/lib/ipc/bridge.ts",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx"
  ],
  "coverageAnalysis": "all",
  "disableTypeChecks": "src/**/*.{ts,tsx}",
  "allowConsoleColors": true,
  "tempDirName": "reports/mutation/.stryker-shell-tmp",
  "thresholds": {
    "high": 100,
    "low": 100,
    "break": 100
  },
  "vitest": {
    "configFile": "vitest.shell.config.ts"
  }
}
