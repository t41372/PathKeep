{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "checkers": ["typescript"],
  "reporters": ["clear-text", "html", "progress"],
  "ignorePatterns": [
    "src-tauri/target/**",
    "coverage/**",
    "dist/**",
    "output/**",
    "test-results/**",
    "var/**"
  ],
  "htmlReporter": {
    "fileName": "reports/mutation/js/index.html"
  },
  "mutate": [
    "src/lib/backend.ts",
    "src/lib/i18n/context.ts",
    "src/lib/i18n/hooks.ts",
    "src/lib/i18n/provider.tsx",
    "src/lib/format.ts",
    "src/lib/intelligence.ts",
    "src/lib/platform-guidance.ts",
    "src/lib/stronghold.ts",
    "src/lib/trust-review.ts",
    "src/app/shell-data.tsx",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx"
  ],
  "coverageAnalysis": "perTest",
  "disableTypeChecks": "src/**/*.{ts,tsx}",
  "allowConsoleColors": true,
  "tempDirName": "reports/mutation/.stryker-tmp",
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 80
  },
  "vitest": {
    "configFile": "vitest.config.ts"
  }
}
